<Window x:Class="DepositCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор вкладов" Height="550" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto" MinWidth="83.097"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Калькулятор доходности вклада" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Width="320"/>

        <!-- Сумма вклада -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма вклада(рублей):" 
                   VerticalAlignment="Center" Margin="5,0,5,0" FontSize="14" Height="18"/>
        <TextBox x:Name="txtAmount" Grid.Row="1" Grid.Column="1" 
                 Width="419" HorizontalAlignment="Left" Margin="5,0,0,0" 
                 VerticalAlignment="Center" FontSize="14" Height="30" Grid.ColumnSpan="2"/>


        <!-- Срок вклада -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Срок вклада(мес.):" 
                   VerticalAlignment="Center" Margin="5,0,5,0" FontSize="14" Height="19"/>
        <TextBox x:Name="txtMonths" Grid.Row="2" Grid.Column="1" 
                 Width="419" HorizontalAlignment="Left" Margin="5,0,0,0" 
                 VerticalAlignment="Center" FontSize="14" Height="31" Grid.ColumnSpan="2"/>

        <!-- Процентная ставка -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Процентная ставка(%):" 
                   VerticalAlignment="Center" Margin="5,0,5,0" FontSize="14" Height="18"/>
        <TextBox x:Name="txtRate" Grid.Row="3" Grid.Column="1" 
                 Width="419" HorizontalAlignment="Left" Margin="5,0,0,0" 
                 VerticalAlignment="Center" FontSize="14" Height="30" Grid.ColumnSpan="2"/>

        <!-- Кнопка расчета -->
        <Button x:Name="btnCalculate" Grid.Row="4" Grid.Column="1" 
                Content="Рассчитать" Click="BtnCalculate_Click" Margin="68,5,68,5"               Background="gray" Foreground="White" 
                FontSize="14" FontWeight="Bold"/>

        <!-- Разделитель -->
        <Rectangle Grid.Row="5" Grid.ColumnSpan="3" Fill="#E0E0E0" Margin="0,10,0,10"/>

        <!-- Результаты -->
        <GroupBox Grid.Row="6" Grid.ColumnSpan="3" Header="Результаты расчета" 
                  Margin="5,5,5,5" Padding="10" FontSize="14" FontWeight="Bold">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Простые проценты:" 
                           FontWeight="Bold" Margin="5"/>
                <TextBlock x:Name="txtSimpleInterest" Grid.Row="1" 
                           Text="" Margin="25,5,5,5" FontSize="13"/>

                <TextBlock Grid.Row="2" Text="Сложные проценты:" 
                           FontWeight="Bold" Margin="5,15,5,5"/>
                <TextBlock x:Name="txtCompoundInterest" Grid.Row="3" 
                           Text="" Margin="25,5,5,5" FontSize="13"/>

                <TextBlock Grid.Row="4" Text="Разница в доходности:" 
                           FontWeight="Bold" Margin="5,15,5,5"/>
                <TextBlock x:Name="txtDifference" Grid.Row="5" 
                           Text="" Margin="25,5,5,5" FontSize="13"/>
            </Grid>
        </GroupBox>

        <!-- Пояснение -->
        <TextBlock Grid.Row="7" Grid.ColumnSpan="3" Text="* Простые проценты начисляются в конце срока, сложные - ежемесячно с капитализацией" 
                   FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="5,5,5,5"/>

    </Grid>
</Window>